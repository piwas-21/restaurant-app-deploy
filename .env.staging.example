# STAGING box .env template. On the staging box: cp .env.staging.example .env and fill in
# (the real file is just ".env" — same gitignored name as prod, since it's a separate box).
# Used by docker-compose.prod.yml (the compose file is shared across both boxes).

# --- Which Caddyfile to mount (this is what makes the shared compose serve staging) ---
CADDYFILE=./Caddyfile.staging

# --- Staging site address (baked into the Caddyfile via {$STAGING_DOMAIN}) ---
# Change this one line to move staging onto a SaaS brand domain later.
STAGING_DOMAIN=v2202607374190477434.megasrv.de

# --- Image versions pulled from GHCR (per service) ---
# Backend is domain-agnostic (URLs/CORS come from app-secrets.json), so staging runs the
# SAME backend image as prod. Only the frontend bakes NEXT_PUBLIC_* at build time, so it
# needs a staging-specific image tag (built by the frontend repo's build-image.yml).
BACKEND_TAG=latest
FRONTEND_TAG=staging

# --- Postgres (fresh, staging-only DB — NEVER point at prod data) ---
POSTGRES_USER=rumi
POSTGRES_DB=restaurantdb
# Generate: openssl rand -base64 32   (trim '/+=' — gen-secrets.sh does this)
POSTGRES_PASSWORD=CHANGE_ME

# --- Developer Portal Basic Auth (/dev-portal) ---
# Bcrypt hash, NOT plaintext. Generate on the box:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'CHOOSE_A_STRONG_PASSWORD'
# IMPORTANT: double every literal $ before pasting (Compose interpolates .env; an
# unescaped $ silently corrupts the hash — see DEPLOYMENT.md).
DEV_PORTAL_AUTH_HASH=CHANGE_ME
