# Copy to .env and fill in. .env is git-ignored. Used by docker-compose.prod.yml.

# --- Image versions pulled from GHCR (per service) ---
# "latest" tracks the current prod (main). deploy.sh persists whatever tag it
# deploys here, so a rollback survives restarts. Pin a specific build for a
# rollback, e.g. BACKEND_TAG=sha-<commit> or FRONTEND_TAG=v1.2.3.
BACKEND_TAG=latest
FRONTEND_TAG=latest

# --- Postgres (fresh DB; you pick these) ---
POSTGRES_USER=rumi
POSTGRES_DB=restaurantdb
# Generate: openssl rand -base64 32   (avoid characters that break the connection string, e.g. trim '/+=')
POSTGRES_PASSWORD=CHANGE_ME

# Note: NEXT_PUBLIC_* (API URL, Google client ID) are baked into the frontend
# image at CI build time — they are NOT set here. To change them, edit the
# frontend repo's build-image.yml and rebuild.

# --- Developer Portal Basic Auth (/dev-portal) ---
# Bcrypt hash, NOT the plaintext password. Generate on the box:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'CHOOSE_A_STRONG_PASSWORD'
# Rotate by regenerating the hash and recreating the caddy service.
DEV_PORTAL_AUTH_HASH=CHANGE_ME
